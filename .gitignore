*.mp4
*.mov
*.webm
assets/video/

# ============================================
#   .gitignore for Static Website (HTML/CSS/JS)
#   twyn Digital — Cloudflare Pages Project
# ============================================


# ── OS FILES ────────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~


# ── EDITOR & IDE ────────────────────────────

# VS Code
.vscode/
!.vscode/extensions.json

# JetBrains (WebStorm etc.)
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace


# ── NODE / NPM (if you ever add tools) ──────

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.npm
.pnp.*


# ── BUILD OUTPUT ────────────────────────────

dist/
build/
out/
.cache/
.parcel-cache/


# ── ENVIRONMENT & SECRETS ───────────────────

.env
.env.local
.env.development
.env.production
.env*.local
*.secret
secrets.js
config.local.js


# ── LOGS ────────────────────────────────────

logs/
*.log


# ── TEMP & BACKUP FILES ─────────────────────

*.tmp
*.temp
*.bak
*.swp
*.swo


# ── ZIP / ARCHIVE FILES ─────────────────────

*.zip
*.tar.gz
*.rar


# ── CLOUDFLARE ──────────────────────────────

.wrangler/
.dev.vars